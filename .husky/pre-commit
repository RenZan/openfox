#!/bin/sh

STAGED=$(git diff --cached --name-only --diff-filter=d)
[ -n "$STAGED" ] && echo "$STAGED" | xargs npx prettier --write --ignore-unknown 1>/dev/null 2>&1
git add -u

TMPDIR=$(mktemp -d)
trap 'rm -rf "$TMPDIR"' EXIT

run_check() {
  name=$1
  shift
  "$@" > "$TMPDIR/$name.log" 2>&1
  echo $? > "$TMPDIR/$name.exit"
}

run_check "lint" npm run lint &
run_check "typecheck" npm run typecheck &
run_check "duplicate" npm run duplicate &
run_check "test" npm test &

remaining=4
while [ $remaining -gt 0 ]; do
  for name in lint typecheck duplicate test; do
    if [ -f "$TMPDIR/$name.exit" ] && [ ! -f "$TMPDIR/$name.done" ]; then
      touch "$TMPDIR/$name.done"
      exit_code=$(cat "$TMPDIR/$name.exit")
      if [ "$exit_code" -eq 0 ]; then
        echo "  $name ✓"
      else
        echo "  $name ✗"
      fi
      remaining=$((remaining - 1))
    fi
  done
  [ $remaining -gt 0 ] && sleep 0.2
done

echo

any_failed=0
for check in lint typecheck duplicate test; do
  exit_code=$(cat "$TMPDIR/$check.exit")
  if [ "$exit_code" -ne 0 ]; then
    any_failed=1
    echo "--- $check ---"
    cat "$TMPDIR/$check.log"
    echo
  fi
done

exit $any_failed
